# ============================================================
#  .gitignore — Product Price Monitoring System
#  Keep the repo clean: no secrets, caches, or local state.
# ============================================================

# ── Python Virtual Environments ──────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Python Bytecode & Caches ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/
.pytype/

# ── Pytest & Coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
pytest.ini
*.log

# ── Databases (SQLite) ───────────────────────────────────────
# Local runtime databases — never commit these.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Secrets & Local Config ───────────────────────────────────
.env
.env.*
!.env.example
secrets.json
config.local.*

# ── OS Generated Files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE & Editor Configs ─────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.workspace
*.sublime-project
*.sublime-workspace

# ── Build / Distribution ─────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
*.whl
*.tar.gz
*.zip

# ── pip Install Artifacts ────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt

# ── Node / Frontend Tooling ──────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Test Databases ───────────────────────────────────────────
# test.db is generated by pytest — do not commit.
test.db
test.db-shm
test.db-wal

# ── Temporary / Backup Files ─────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
~$*

# ── Explicitly Allowed ───────────────────────────────────────
# (Overrides the general *.txt exclusion if you had one)
!requirements.txt
!README.md
